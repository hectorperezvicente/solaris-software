{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ESP32-S3  ·  Build + Flash + Debug",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/solaris-v1/build/solaris-v1.elf",
      "cwd": "${workspaceFolder}/solaris-v1",
      "MIMode": "gdb",
      "miDebuggerPath": "${workspaceFolder}/.devcontainer/docker-gdb.sh",
      "miDebuggerServerAddress": "127.0.0.1:3334",
      "externalConsole": false,
      "stopAtEntry": true,
      "preLaunchTask": "full-debug-prepare",
      "launchCompleteCommand": "exec-continue",
      "setupCommands": [
        { "text": "set confirm off" },
        { "text": "set pagination off" },
        { "text": "set breakpoint pending on" },
        { "text": "set remotetimeout 5" },
        { "text": "set print pretty on" },
        { "text": "set step-mode on" },
        { "text": "thb app_main" }
      ]
    },
    {
      "name": "ESP32-S3 Debug (OpenOCD remoto)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/solaris-v1/build/solaris-v1.elf",
      "cwd": "${workspaceFolder}/solaris-v1",
      "MIMode": "gdb",
      "miDebuggerPath": "${workspaceFolder}/.devcontainer/docker-gdb.sh",
      "miDebuggerServerAddress": "127.0.0.1:3334",
      "externalConsole": false,
      "stopAtEntry": true,
      "preLaunchTask": "gdb-prepare",
      "postDebugTask": "ssh-tunnel-openocd-down",
      "launchCompleteCommand": "exec-continue",
      "setupCommands": [
        { "text": "set confirm off" },
        { "text": "set pagination off" },
        { "text": "set breakpoint pending on" },
        { "text": "set remotetimeout 5" },
        { "text": "set print pretty on" },
        { "text": "set step-mode on" },
        { "text": "thb app_main" }
      ]
    }
  ]
}
